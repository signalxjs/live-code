{
    "name": "sigx-live-code-monorepo",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.33.4",
    "description": "Monorepo for @sigx/live-code — interactive code blocks with a prebundled Monaco editor",
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "build": "pnpm --filter @sigx/live-code run build",
        "generate:types": "pnpm --filter @sigx/live-code run generate:types",
        "typecheck": "tsgo --noEmit",
        "lint": "oxlint packages/live-code/src",
        "lint:fix": "oxlint --fix packages/live-code/src",
        "publish:dry": "node scripts/publish.js --dry-run",
        "publish:all": "node scripts/publish.js",
        "publish:beta": "node scripts/publish.js --tag beta",
        "verify:pack": "node scripts/verify-pack.js",
        "version:set": "node scripts/bump-version.js",
        "version:patch": "node scripts/bump-version.js patch",
        "version:minor": "node scripts/bump-version.js minor",
        "version:major": "node scripts/bump-version.js major",
        "size": "size-limit",
        "clean": "node -e \"const fs=require('fs'),p=require('path');const rm=x=>fs.rmSync(x,{recursive:true,force:true});for(const d of fs.readdirSync('packages')){rm(p.join('packages',d,'dist'));rm(p.join('packages',d,'node_modules'));}rm('node_modules');rm('pnpm-lock.yaml');\""
    },
    "devDependencies": {
        "@size-limit/preset-small-lib": "^11",
        "@typescript/native-preview": "7.0.0-dev.20260514.1",
        "oxlint": "^1.64.0",
        "size-limit": "^11",
        "typescript": "^5.9.3",
        "vitest": "^4.1.6"
    },
    "keywords": [
        "sigx",
        "signalx",
        "live-code",
        "playground",
        "documentation"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/live-code.git"
    },
    "homepage": "https://github.com/signalxjs/live-code",
    "bugs": {
        "url": "https://github.com/signalxjs/live-code/issues"
    }
}
